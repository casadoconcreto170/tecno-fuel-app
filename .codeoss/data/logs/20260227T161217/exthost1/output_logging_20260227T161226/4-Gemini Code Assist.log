\n      appType: \"spa\",\n    });\n    app.use(vite.middlewares);\n  }\n\n  app.listen(PORT, \"0.0.0.0\", () =\u003e {\n    console.log(`Servidor rodando na porta ${PORT}`);\n  });\n}\n\nstartServer();"}}
